[package]
name = "ext4plus"
version = "0.1.0-rc.2"
edition.workspace = true
license.workspace = true
repository = "https://github.com/arihant2math/ext4plus"
categories = ["filesystem", "embedded", "no-std", "asynchronous"]
description = "No-std compatible Rust library for ext2/ext3/ext4 filesystems"
keywords = ["ext4", "ext2", "ext3", "filesystem", "no_std"]
rust-version = "1.86"
include = [
    "src/*.rs",
    "src/file_blocks",
    "src/iters",
    "src/journal",
    "LICENSE-APACHE",
    "LICENSE-MIT",
]

[workspace]
members = ["xtask"]

[workspace.package]
edition = "2024"
license = "MIT OR Apache-2.0"

[workspace.dependencies]
anyhow = { version = "1.0", features = ["backtrace"] }

[features]
default = ["multi-threaded"]
multi-threaded = []
std = []
sync = ["maybe-async/is_sync", "dep:spin"]

[dependencies]
async-lock = { version = "3.4", default-features = false }
async-trait = "0.1"
bitflags = "2.0"
crc = "3.0"
maybe-async = "0.2"
spin = { version = "0.10", optional = true }

[dev-dependencies]
anyhow.workspace = true
tempfile = "3"
tokio = { version = "1", features = [
    "fs",
    "io-util",
    "io-std",
    "macros",
    "rt",
    "rt-multi-thread",
] }

[package.metadata.docs.rs]
all-features = true
rustdoc-args = ["--cfg", "docsrs"]
