#!/usr/bin/env bash
set -euo pipefail

sysroot=$(rustc --print sysroot)
host=$(rustc -vV | sed -n 's/^host: //p')
tool="$sysroot/lib/rustlib/$host/bin/rust-objcopy"

if [[ ! -x "$tool" ]]; then
    echo "rust-objcopy not found at $tool; install the llvm-tools component for this toolchain" >&2
    exit 1
fi

exec "$tool" "$@"
